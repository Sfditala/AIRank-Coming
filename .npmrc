# ─── npm configuration for AiRank ────────────────────────────────────────────
#
# legacy-peer-deps: treat peer dependencies the same way npm v6 did — install
# them without failing on conflicts. Required because some packages in this
# project declare peer deps that overlap across the React 19 / TanStack /
# Radix ecosystem.
legacy-peer-deps=true

# Always save exact versions when running `npm install <pkg>` ad-hoc, so the
# lock file stays deterministic.
save-exact=false

# Suppress the npm fund / audit output noise during installs.
fund=false
audit=false

# Serve packages from cache when available; only hit network for missing ones.
# This makes installs resilient to ECONNRESET on slow/unstable connections.
prefer-offline=true
